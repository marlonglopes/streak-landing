# Supabase — get these from your project settings: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Used by admin operations (auto profile creation, Stripe webhooks).
# NEVER prefix with NEXT_PUBLIC_ — this key bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (fill in when Phase 3 starts)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
