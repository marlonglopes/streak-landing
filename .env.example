# Supabase — get these from your project settings: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Used by admin operations (auto profile creation, Stripe webhooks).
# NEVER prefix with NEXT_PUBLIC_ — this key bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (fill in when Phase 3 starts)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Mailchimp Transactional (Mandrill) — reminder emails, Sprint 2.3.
# Create the API key at https://mandrillapp.com/settings — verify the sending
# domain (SPF + DKIM) before flipping MANDRILL_DRY_RUN off.
MANDRILL_API_KEY=md-your-mandrill-api-key
MANDRILL_FROM_EMAIL=reminders@yourdomain.com
MANDRILL_FROM_NAME=Streak

# Set to 1 to log the payload and skip the actual API call. Default: 1 in dev.
MANDRILL_DRY_RUN=1

# Shared secret Vercel Cron sends in the `Authorization: Bearer` header.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-string

# HMAC key for one-click unsubscribe tokens in email footers. Long-lived —
# rotating invalidates every outstanding token, so rotate rarely.
# Generate with: openssl rand -hex 32
UNSUB_TOKEN_SECRET=replace-with-a-long-random-string

# Base URL used when building absolute links inside emails (unsub, check-in).
# Dev: http://localhost:3000 · prod: https://streak.app (or your domain).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
